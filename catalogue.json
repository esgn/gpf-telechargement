{
  // Catalogue éditorial du site de téléchargement Géoplateforme.
  // L'API IGN ne fournit aucune métadonnée éditoriale : titre affichable, thème,
  // résumé et liens de spécification sont maintenus ICI, joints au crawl via « id »
  // (le nom exact de la ressource dans .../resource/{id}).
  //
  // Ce fichier tolère les commentaires « // » et les virgules finales (cf.
  // gpf/catalogue.py:strip_json_comments). Pour masquer un produit sans le
  // supprimer : "include": false. Pour lister les nouveaux produits de l'API
  // absents d'ici : python build.py --check

  // Présentation du site web généré (titres, textes, garde-fou d'affichage).
  "site": {
    "title": "Téléchargement Géoplateforme",
    // Chapô affiché sous le titre de l'accueil (texte simple ; vide = pas de chapô).
    "intro": "Parcourez et téléchargez les données ouvertes de l'IGN diffusées par le service de téléchargement de la Géoplateforme, organisées par thème.",
    "official_help_url": "https://cartes.gouv.fr/aide/fr/guides-utilisateur/utiliser-les-services-de-la-geoplateforme/telechargement/",
    // Bloc « aide » en bas de l'accueil : phrase + libellé du lien (vers official_help_url).
    // help_text vide → bloc masqué.
    "help_text": "Besoin d'aide sur le service de téléchargement ? Voir",
    "help_link_label": "la documentation officielle cartes.gouv.fr",
    // Pied de page, en Markdown (liens autorisés). « Généré le <date>. » est préfixé
    // automatiquement au build.
    "footer": "Index non officiel. Données diffusées par l'IGN via [data.geopf.fr](https://data.geopf.fr) ; ce site n'héberge aucune donnée et pointe les liens de téléchargement directement vers data.geopf.fr.",
    // Garde-fou d'affichage : un dossier dépassant ce nombre d'entrées n'est pas
    // déplié (le service pourrait en servir davantage). 0 = illimité.
    "max_entries": 50000
  },

  // Accès au service de téléchargement interrogé (l'API Géoplateforme).
  "service": {
    "base_url": "https://data.geopf.fr/telechargement",
    "capabilities_path": "/capabilities"
  },

  // Producteurs affichés sur les cartes produit. Chaque produit référence un
  // producteur par son « id » (champ "producer"). « logo » est un chemin relatif
  // au dossier assets/ (copié tel quel vers site/assets/ au build) : si présent,
  // le logo est affiché sur la carte, sinon le « name » l'est en texte. Un produit
  // sans "producer" (ou avec un producteur inconnu) n'affiche aucun badge.
  "producers": [
    { "id": "ign", "name": "IGN", "logo": "logos/ign.svg" },
    { "id": "insee", "name": "INSEE", "logo": "logos/insee.svg" },
    { "id": "sdes", "name": "SDES", "logo": "logos/sdes.svg" },
    { "id": "inrae", "name": "INRAE", "logo": "logos/inrae.svg" },
    { "id": "ofb", "name": "OFB", "logo": "logos/ofb.svg" },
    { "id": "inpn", "name": "INPN", "logo": "logos/inpn.svg" }
  ],

  // Thèmes dans l'ordre d'affichage. Un produit sans thème (ou thème inconnu)
  // atterrit dans « Autres jeux de données ».
  "themes": [
    { "id": "topo",        "label": "Référentiels topographiques" },
